# ══════════════════════════════════════════════════════════════
# Takone — Environment Variables
# Copy to .env and fill in your keys. Only configure the
# providers you plan to use; everything else can stay commented.
# ══════════════════════════════════════════════════════════════

# ── LLM Providers ────────────────────────────────────────────
# At least one is required. Set LLM_PROVIDER to choose which.

# MiniMax (default LLM, model: MiniMax-M2.7)
MINIMAX_API_KEY=

# Kimi / Moonshot AI (model: kimi-k2.5, also used for Kimi vision)
# MOONSHOT_API_KEY=

# Zhipu GLM (LLM: glm-5, Vision: glm-4.6v)
# ZHIPU_API_KEY=

# Anthropic Claude (model: claude-sonnet-4-20250514)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (model: gpt-4o)
# OPENAI_API_KEY=sk-...

# Alibaba Qwen / DashScope (LLM + Vision: qwen3.5-plus)
# Supports both QWEN_API_KEY and DASHSCOPE_API_KEY
# QWEN_API_KEY=
# DASHSCOPE_API_KEY=

# ── Volcengine ARK (字节跳动/豆包) ─────────────────────────────
# Shared across: Doubao LLM, Jimeng/Seedream image gen, Seedance video gen, Doubao vision
ARK_API_KEY=

# ── Image Generation ─────────────────────────────────────────
# Jimeng/Seedream uses ARK_API_KEY by default.
# Set JIMENG_API_KEY only if you need a separate key.
# JIMENG_API_KEY=

# Gemini image generation
# GEMINI_API_KEY=

# ── Video Generation ─────────────────────────────────────────
# Seedance uses ARK_API_KEY by default.
# MiniMax video uses a separate key if needed.
# MINIMAX_VIDEO_API_KEY=

# ── Provider Overrides ───────────────────────────────────────
# Override config.yaml defaults via env vars.
# Or use `takone config` / `/config` for interactive setup.
#
# LLM_PROVIDER=minimax        # minimax | kimi | zhipu | claude | openai | doubao | moonshot | qwen
# IMAGE_PROVIDER=jimeng       # jimeng | gemini
# VIDEO_PROVIDER=seedance     # seedance | minimax | sora

# ── Project Settings ─────────────────────────────────────────
# TAKONE_PROJECTS=~/Takone    # Projects directory (default: ~/Takone)

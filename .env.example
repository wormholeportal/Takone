# Takone Configuration
# Minimax API Key (★ default LLM provider)
MINIMAX_API_KEY=...

# Optional: Other LLM providers
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Volcengine (ARK) — shared by Jimeng image + Seedance video + Doubao LLM
ARK_API_KEY=...

# Optional: separate Jimeng key (falls back to ARK_API_KEY)
# JIMENG_API_KEY=...

# Optional providers
# MINIMAX_VIDEO_API_KEY=...
# GEMINI_API_KEY=...

# Override defaults
# LLM_PROVIDER=minimax
# IMAGE_PROVIDER=jimeng
# VIDEO_PROVIDER=seedance

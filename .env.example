# ══════════════════════════════════════════════════════════════
# Takone — Environment Variables
# Copy to .env and fill in your keys. Only configure the
# providers you plan to use; everything else can stay commented.
# ══════════════════════════════════════════════════════════════

# ── Volcengine ARK (Bytedance) ─────────────────────────────
# One key for everything: Doubao LLM, Jimeng/Seedream image,
# Seedance video, Doubao vision.
ARK_API_KEY=

# ── LLM Providers ────────────────────────────────────────────
# At least one is required. Set LLM_PROVIDER to choose which.

# MiniMax (default, model: MiniMax-M2.7)
MINIMAX_API_KEY=

# Kimi / Moonshot AI (model: kimi-k2.5, also used for Kimi vision)
# MOONSHOT_API_KEY=

# Zhipu GLM (LLM: glm-5, Vision: glm-4.6v)
# ZHIPU_API_KEY=

# Anthropic Claude (model: claude-sonnet-4-20250514)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (model: gpt-4o)
# OPENAI_API_KEY=sk-...

# Alibaba Qwen / DashScope (LLM + Vision: qwen3.5-plus)
# QWEN_API_KEY=
# DASHSCOPE_API_KEY=

# ── Image Generation ─────────────────────────────────────────
# Jimeng/Seedream uses ARK_API_KEY by default.
# Only set these if you need a separate key or custom endpoint.
# JIMENG_API_KEY=
# JIMENG_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# JIMENG_MODEL=doubao-seedream-5-0-260128

# Gemini image generation
# GEMINI_API_KEY=

# ── Video Generation ─────────────────────────────────────────
# Seedance uses ARK_API_KEY by default.
# Only set these if you need a custom endpoint or model.
# SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215

# MiniMax video (separate key if needed)
# MINIMAX_VIDEO_API_KEY=

# ── Provider Overrides ───────────────────────────────────────
# LLM_PROVIDER=minimax        # minimax | kimi | zhipu | claude | openai | doubao | moonshot | qwen
# IMAGE_PROVIDER=jimeng       # jimeng | gemini
# VIDEO_PROVIDER=seedance     # seedance | minimax | sora

# ── Project Settings ─────────────────────────────────────────
# TAKONE_PROJECTS=~/Takone    # Projects directory (default: ~/Takone)
